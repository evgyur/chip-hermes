# Copy to $HERMES_HOME/.env on the target server and fill values there.
# Do not commit real secrets.

TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_ALLOWED_USER_IDS=replace_with_comma_separated_user_ids
TELEGRAM_ALLOWED_USERS=replace_with_operator_telegram_user_id_for_business_trust

# Do not use wildcard allow-all values as Telegram Business trust.
# External Business contacts must stay in web-only safe mode unless explicitly trusted.
TELEGRAM_ALLOW_ALL_USERS=false
GATEWAY_ALLOW_ALL_USERS=false

MINIMAX_API_KEY=replace_with_minimax_token_plan_key
GROQ_API_KEY=replace_with_groq_api_key

# Optional model/key sources for memory or fallback providers.
OPENROUTER_API_KEY=replace_with_openrouter_key_if_used
OPENAI_API_KEY=replace_with_openai_key_if_used

# Cognee defaults. Keep runtime roots per user/profile.
COGNEE_LLM_PROVIDER=openai
COGNEE_LLM_MODEL=deepseek/deepseek-chat-v3
COGNEE_EMBEDDING_PROVIDER=openai
COGNEE_EMBEDDING_MODEL=openai/text-embedding-3-large
COGNEE_RUNTIME_DIR=$HERMES_HOME/cognee
CACHING=true
CACHE_BACKEND=fs
